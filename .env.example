# Copy to ".env" and adjust as needed: cp .env.example .env

# MegaMek release to build. Use "latest" for the newest GitHub release,
# or pin a specific version, e.g. MM_VERSION=0.50.12
MM_VERSION=latest

# Port the dedicated server listens on (host + container).
MM_PORT=2346

# Max JVM heap.
MM_XMX=4096m

# Optional: load a saved game on startup (path is relative to the app dir,
# saves live under the persisted savegames volume).
# MM_SAVEGAME=savegames/mygame.sav.gz

# Optional: any extra MegaMek command-line arguments.
# MM_EXTRA_ARGS=
